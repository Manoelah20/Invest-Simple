{
  "version": 2,
  "installCommand": "npm install",
  "builds": [
    { "src": "frontend/**", "use": "@vercel/static" },
    { "src": "backend/server.js", "use": "@vercel/node" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "backend/server.js" },
    { "source": "/(.*)", "destination": "frontend/index.html" }
  ]
}
